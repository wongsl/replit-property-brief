modules = ["nodejs-20", "python-3.11", "bash", "web", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["remote-exec"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd backend && python3.11 manage.py migrate && python3.11 create_admin.py && cd .. && python3.11 -m gunicorn --bind=127.0.0.1:8000 property_brief.wsgi:application --chdir backend & SKIP_DJANGO_SPAWN=true PORT=5000 node dist/index.cjs"]
build = ["bash", "-c", "python3.11 -m pip install -r requirements.txt && npm run build"]

[userenv]

[userenv.shared]
